# Copy this file to .env. Never commit the resulting .env file.

# Transitional shared runtime paths. ArcadeDB is the canonical tenant store;
# these TURINGDB_* names remain until the later compatibility cleanup.
TURINGDB_URL=http://turingdb:6666
TURINGDB_GRAPH=agent_memory
TURINGDB_HOME=/turing

# ArcadeDB connection. Production tenant routing never uses a shared
# ARCADEDB_DATABASE; each exact user_identifier maps to its own opaque database.
ARCADEDB_URL=http://arcadedb:2480
ARCADEDB_USER=root
# MUST be overridden for any non-loopback deployment; the 127.0.0.1-only port
# publish (compose.yaml's arcadedb service) is the primary guard for local
# dev, not this password's strength. This is the single documented source of
# this dev-only default -- compose.yaml repeats the literal value at each of
# its three ARCADEDB_PASSWORD env entries (Compose's `${VAR:-default}`
# interpolation has no cross-referencing mechanism) but points back here.
ARCADEDB_PASSWORD=agentmemory-arcadedb-dev

# Per-tenant ArcadeDB routing. Generate the required naming key with:
# python -c "import base64,secrets; print(base64.b64encode(secrets.token_bytes(32)).decode())"
# Keep one stable value for the deployment; changing it requires an explicit migration.
AGENTMEMORY_TENANT_NAMING_KEY=
AGENTMEMORY_TENANT_REGISTRY_PATH=/turing/data/agent-memory-tenant-registry.sqlite3
AGENTMEMORY_TENANT_CACHE_CAPACITY=128
AGENTMEMORY_TENANT_CACHE_IDLE_TTL_SECONDS=900
AGENTMEMORY_TENANT_PROVISION_ATTEMPTS=3
AGENTMEMORY_TENANT_PROVISION_BACKOFF_BASE_SECONDS=0.25
AGENTMEMORY_TENANT_PROVISION_BACKOFF_MAX_SECONDS=2.0

# Local OpenAI-compatible providers used by the default Compose stack
EMBED_BASE_URL=http://agentmemory-embed:8080
EMBED_MODEL=mykor/granite-embedding-311m-multilingual-r2-GGUF:Q4_K_M
EMBED_DIMENSIONS=768
EMBED_BATCH_SIZE=128
RERANK_BASE_URL=http://agentmemory-rerank:8080
RERANK_MODEL=Qwen3-Reranker-0.6B-q8_0.gguf
RERANK_CANDIDATE_LIMIT=50
RERANK_PROVIDER_MIN_SCORE=0
RERANK_BLEND=1

# Optional shared cloud-provider credentials. Prefer provider-specific keys.
# PROVIDER_API_KEY=
# EMBED_API_KEY=
# RERANK_API_KEY=
# PROVIDER_API_KEY_HEADER=Authorization
# PROVIDER_API_KEY_SCHEME=Bearer

# Tenant-safe HTTP authentication. Set at least one for non-local deployment.
# AGENTMEMORY_AUTH_TOKEN=replace-with-a-long-random-token
# AGENTMEMORY_AUTH_TOKENS=active-token,previous-token
# AGENTMEMORY_AUTH_REQUIRED_SCOPES=memory:read,memory:write

# Governance and content-free telemetry
AGENTMEMORY_REDACTION_ENABLED=1
AGENTMEMORY_AUDIT_JSONL=/turing/audit/agentmemory.jsonl
AGENTMEMORY_OBSERVABILITY_JSONL=/turing/audit/spans.jsonl
AGENTMEMORY_OBSERVABILITY_STDERR=0

# Durable asynchronous document ingestion
AGENTMEMORY_DOCUMENT_JOB_LEASE_SECONDS=900
AGENTMEMORY_DOCUMENT_JOB_HEARTBEAT_SECONDS=15
AGENTMEMORY_DOCUMENT_JOB_POLL_SECONDS=1
AGENTMEMORY_DOCUMENT_JOB_MAX_ATTEMPTS=3
AGENTMEMORY_UPLOAD_MAX_FILE_BYTES=134217728
AGENTMEMORY_UPLOAD_CHUNK_BYTES=524288

# Local file-pipe process. Use the host path separator for multiple roots.
# AGENTMEMORY_REMOTE_MCP_URL=http://127.0.0.1:8095/mcp/
# AGENTMEMORY_FILE_PIPE_ROOTS=D:\documents
# AGENTMEMORY_FILE_PIPE_CHUNK_BYTES=524288
